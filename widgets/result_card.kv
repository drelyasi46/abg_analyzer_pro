<ResultCard>:
    orientation: "vertical"
    size_hint_y: None
    height: "450dp"

    MDCard:
        orientation: "vertical"
        padding: "12dp"
        spacing: "10dp"
        radius: [18]
        elevation: 3

        MDLabel:
            text: "ABG Report"
            halign: "center"
            bold: True
            size_hint_y: None
            height: "35dp"

        ScrollView:
            do_scroll_x: False

            Label:
                id: report
                text: "Ready for analysis..."
                font_size: "16sp"
                color: 0, 0, 0, 1

                size_hint_y: None
                text_size: self.width, None
                height: self.texture_size[1]

                halign: "left"
                valign: "top"